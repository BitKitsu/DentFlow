# PostgreSQL
POSTGRES_DB=dentflow
POSTGRES_USER=dentflow
POSTGRES_PASSWORD=dentflow123

# Spring Boot datasource (used by both services)
# docker-compose overrides this to jdbc:postgresql://postgres:5432/dentflow
# For local dev without Docker, keep localhost:
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/dentflow
SPRING_DATASOURCE_USERNAME=dentflow
SPRING_DATASOURCE_PASSWORD=dentflow123

# JWT (min 32 chars, generate with: openssl rand -hex 32)
JWT_SECRET=dentflow-dev-secret-change-in-production-32ch
# Czas waznosci tokenu
JWT_EXPIRATION=86400000 # 24h w ms

# SendGrid (email - potwierdzenia wizyt, przypomnienia)
# Klucz API z https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.placeholder

# Mail
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey

# S3 (MinIO for local dev, AWS S3 / Railway Object Storage for production)
# Local MinIO: http://localhost:9000 (console: http://localhost:9001)
# MinIO defaults: minioadmin / minioadmin
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
AWS_REGION=us-east-1
S3_BUCKET_NAME=dentflow
